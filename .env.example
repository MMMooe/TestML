# Backend runtime
APP_MODE=production-cuda
APP_REQUIRE_TENSORRT=true
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_MAX_UPLOAD_MB=4096

# scripts/start_conda.sh defaults this to the repository storage/ folder.
# Set an absolute path here only if you want runtime data elsewhere.
# APP_STORAGE_DIR=/absolute/path/to/TestLM/storage
